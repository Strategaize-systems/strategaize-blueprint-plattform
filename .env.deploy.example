# ── Strategaize Blueprint Plattform — Production Environment ──────────
# Kopiere diese Datei als .env auf dem Hetzner-Server.
# Alle Werte MÜSSEN vor dem ersten Start gesetzt werden.

# === App ===
NEXT_PUBLIC_APP_URL=https://blueprint.strategaizetransition.com

# === Supabase — DUAL-URL-STRATEGIE (KRITISCH) ===
# Server-seitig (API Routes, Server Actions, Middleware):
#   → Interne Docker-URL via Kong. Darf NICHT die externe URL sein (Hairpin NAT).
SUPABASE_URL=http://supabase-kong:8000

# Browser-seitig (Client Components, NEXT_PUBLIC_*):
#   → Externe URL über Coolify/Caddy Reverse Proxy.
#   → Wird zur BUILD-TIME eingebettet. Muss beim Build verfügbar sein.
NEXT_PUBLIC_SUPABASE_URL=https://blueprint.strategaizetransition.com/supabase

# === JWT Keys ===
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_ME_MIN_32_CHARS

# Anon Key und Service Role Key müssen als JWTs mit dem JWT_SECRET signiert werden.
# Generieren: node scripts/generate-secrets.mjs
NEXT_PUBLIC_SUPABASE_ANON_KEY=GENERATE_ME_SEE_DOCS
SUPABASE_SERVICE_ROLE_KEY=GENERATE_ME_SEE_DOCS

# === Database ===
POSTGRES_PASSWORD=GENERATE_ME_STRONG_PASSWORD

# === Realtime ===
# Generieren: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REALTIME_SECRET=GENERATE_ME_MIN_64_CHARS

# === SMTP (PFLICHT für Invite-Emails — ohne SMTP können keine User eingeladen werden) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@strategaizetransition.com

# === LLM (Ollama — lokal auf Hetzner, DSGVO-konform) ===
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:14b

# === Storage ===
# 200 MB pro Datei. Gesamtkapazität abhängig von Hetzner-Disk.
STORAGE_FILE_SIZE_LIMIT=209715200
